# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# 环境变量（含密钥，禁止提交）
.env

# 数据集（体积大，按需下载，不入库；但保留下载说明与脚本）
dataset/*
!dataset/DOWNLOAD.md
!dataset/download_azure_v2.sh

# IDE / 工具
.trae/
.idea/
.vscode/
*.log

# uv 锁文件（按需保留，建议不入库以避免跨平台冲突）
# uv.lock

# 评估运行期产物（断点续跑 checkpoint）
eval/reports/*.jsonl

# 临时备份与 patch 文件
*.bak_v*
*.patch
*.bak
