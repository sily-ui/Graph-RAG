# ===== Neo4j 图数据库 =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=请改成你设置的密码

# ===== 生成 LLM（用于查询规划、Cypher生成、答案合成）=====
# 推荐用 OpenAI GPT-4o 或 DeepSeek
GEN_LLM_PROVIDER=openai
GEN_LLM_API_KEY=请填入你的API Key
GEN_LLM_BASE_URL=https://api.openai.com/v1
GEN_LLM_MODEL=gpt-4o

# 如果用 DeepSeek，取消注释下面三行，注释上面 OpenAI 配置
# GEN_LLM_PROVIDER=openai
# GEN_LLM_API_KEY=请填入DeepSeek Key
# GEN_LLM_BASE_URL=https://api.deepseek.com/v1
# GEN_LLM_MODEL=deepseek-v4-flash  # 原 deepseek-chat 已停用，推荐用 v4-flash

# ===== 核验 LLM（用于幻觉检测的蕴含判定，必须与生成LLM不同provider）=====
# 推荐用另一家，避免自评偏置
VERIFY_LLM_PROVIDER=openai
VERIFY_LLM_API_KEY=请填入另一个API Key
VERIFY_LLM_BASE_URL=https://api.openai.com/v1
VERIFY_LLM_MODEL=gpt-4o-mini

# 如果用 DeepSeek 做核验，取消注释下面四行，注释上面 OpenAI 配置
# VERIFY_LLM_PROVIDER=openai
# VERIFY_LLM_API_KEY=请填入DeepSeek Key
# VERIFY_LLM_BASE_URL=https://api.deepseek.com/v1
# VERIFY_LLM_MODEL=deepseek-v4-pro  # 原 deepseek-reasoner 已停用，推荐用 v4-pro

# ===== Graphiti 配置 =====
# 是否在摄入时使用 LLM 抽取实体关系
GRAPHITI_USE_LLM_EXTRACT=true
# group_id 前缀，用于隔离不同故障场景
GROUP_ID_PREFIX=cluster
